# generate.sh local config — copy to .env and edit.
# .env is sourced before CLI args are parsed, so any CLI flag overrides these.
# Lines are bash assignments; quote values with spaces.

# Output location (otherwise: current directory)
# OUTPUT_DIR="$HOME/Documents/bed-mat-stls"

# Explicit OpenSCAD binary (otherwise: auto-detected from PATH / /Applications)
# OPENSCAD="/Applications/OpenSCAD.app/Contents/MacOS/OpenSCAD"

# --- Print / material defaults ---
# MATERIAL="ASA"           # PLA | PETG | ASA | ABS | Custom
# SHRINKAGE=""             # override material shrinkage % (-1 = use material default)
# HEIGHT="64"              # body height above mat surface (mm)
# CLEARANCE="0"            # fit clearance per side (mm); negative = tighter
# WALL_WIDTH="0"           # body wall width; 0 = auto

# --- Grid ---
# SPACING="diagonal"       # diagonal (OEM) | dense (every recess)

# --- Fit features (pass-through: set true or false) ---
# LOCK_BUMPS="true"        # snap-in retention bumps
# LOCK_RADIUS="2.0"
# LOCK_PROTRUSION="0.4"
# LOCK_DEPTH="13.1"
# ADD_RIBS="false"         # friction ribs on arm sides
# RIB_RADIUS="0.3"

# --- Geometry defaults (rarely useful as defaults; usually per-invocation) ---
# HALF_UNITS="2"           # straight wall length
# UNITS_X="1"              # corner/tee X leg
# UNITS_Y="1"              # corner/tee Y leg
# JOINT="false"            # interface at corner/tee joint
# WALL_OFFSET="0"
# WALL_POSITION="none"     # corner: none | inside | outside
# STEM_POSITION="none"     # tee: none | left | right
# CAP_THICKNESS="3"        # plug
# FINGER_NOTCH="true"      # plug
